<!doctype html>
<html lang="cs">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Zlatá trefa | audioguide</title>
<meta name="description" content="Audioguide k výstavě Zlatá trefa: příběh olympijského vítěze Josefa Panáčka.">
<link rel="manifest" href="manifest.webmanifest">
<meta name="theme-color" content="#f05a43">
<style>
:root {
  --ink: #12182d;
  --navy: #18244c;
  --blue: #22346f;
  --orange: #f05a43;
  --orange-deep: #c9402f;
  --paper: #fff9f3;
  --panel: rgba(255,255,255,.82);
  --muted: #6c7184;
  --line: rgba(24,36,76,.14);
  --shadow: 0 22px 70px rgba(18,24,45,.18);
  --radius: 26px;
}
* { box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  margin: 0;
  font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif;
  color: var(--ink);
  background:
    radial-gradient(circle at 15% 5%, rgba(240,90,67,.26), transparent 25rem),
    radial-gradient(circle at 95% 15%, rgba(34,52,111,.18), transparent 28rem),
    linear-gradient(180deg, #fff4ec 0%, #f7efe7 42%, #efe8de 100%);
  min-height: 100vh;
}
body::before {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  opacity: .26;
  background-image: linear-gradient(rgba(24,36,76,.045) 1px, transparent 1px), linear-gradient(90deg, rgba(24,36,76,.045) 1px, transparent 1px);
  background-size: 34px 34px;
}
button, input { font: inherit; }
.app-shell { width: min(1180px, calc(100% - 32px)); margin: 0 auto; padding: 24px 0 120px; position: relative; }
.topbar { display: flex; align-items: center; justify-content: space-between; gap: 18px; margin-bottom: 24px; }
.brand { display: flex; align-items: center; gap: 14px; min-width: 0; }
.brand-mark { width: 54px; height: 54px; border-radius: 18px; background: var(--orange); box-shadow: inset 0 -8px 0 rgba(0,0,0,.09), 0 14px 35px rgba(240,90,67,.3); display: grid; place-items: center; flex: 0 0 auto; }
.targets { width: 36px; height: 36px; position: relative; }
.targets span { position: absolute; width: 16px; height: 16px; border-radius: 50%; background: radial-gradient(circle, #ffd8c7 0 18%, #d64734 20% 44%, #f27c61 46% 66%, #b83428 68% 100%); box-shadow: 0 2px 4px rgba(0,0,0,.18); }
.targets span:nth-child(1) { left: 0; top: 6px; }
.targets span:nth-child(2) { left: 10px; top: 0; }
.targets span:nth-child(3) { left: 20px; top: 8px; }
.targets span:nth-child(4) { left: 8px; top: 18px; }
.brand h1 { margin: 0; color: var(--navy); font-size: clamp(26px, 4vw, 52px); line-height: .9; letter-spacing: -.055em; text-transform: uppercase; font-weight: 900; }
.brand p { margin: 4px 0 0; color: var(--muted); font-size: 14px; }
.mode-pill { color: var(--paper); background: var(--navy); border-radius: 999px; padding: 10px 14px; font-size: 13px; white-space: nowrap; box-shadow: var(--shadow); }
.hero { display: grid; grid-template-columns: 1.15fr .85fr; gap: 22px; align-items: stretch; }
.hero-card, .stop-card, .panel-card, .script-card, .info-card { background: var(--panel); border: 1px solid rgba(255,255,255,.9); backdrop-filter: blur(18px); border-radius: var(--radius); box-shadow: var(--shadow); }
.hero-card { padding: clamp(22px, 4vw, 38px); overflow: hidden; position: relative; }
.hero-card::after { content: ""; position: absolute; width: 260px; height: 260px; right: -80px; top: -80px; border-radius: 50%; background: rgba(240,90,67,.12); }
.eyebrow { display: inline-flex; gap: 8px; align-items: center; color: var(--orange-deep); font-weight: 800; text-transform: uppercase; letter-spacing: .12em; font-size: 12px; }
.eyebrow::before { content: ""; width: 8px; height: 8px; border-radius: 50%; background: var(--orange); box-shadow: 14px 0 0 rgba(240,90,67,.45), 28px 0 0 rgba(240,90,67,.22); }
.hero-card h2 { margin: 18px 0 12px; color: var(--navy); font-size: clamp(30px, 6vw, 74px); line-height: .9; letter-spacing: -.065em; text-transform: uppercase; font-weight: 950; max-width: 900px; }
.hero-card .lead { font-size: clamp(17px, 2.2vw, 22px); line-height: 1.45; max-width: 760px; margin: 0; color: #293458; }
.hero-actions { margin-top: 28px; display: flex; gap: 12px; flex-wrap: wrap; }
.primary, .secondary, .ghost { border: 0; border-radius: 999px; padding: 12px 18px; cursor: pointer; transition: transform .18s ease, box-shadow .18s ease, background .18s ease; }
.primary { background: var(--orange); color: white; font-weight: 800; box-shadow: 0 12px 24px rgba(240,90,67,.28); }
.secondary { background: var(--navy); color: white; font-weight: 800; box-shadow: 0 12px 24px rgba(24,36,76,.22); }
.ghost { background: rgba(255,255,255,.68); color: var(--navy); border: 1px solid var(--line); }
.primary:hover, .secondary:hover, .ghost:hover { transform: translateY(-1px); }
.info-card { padding: 22px; display: flex; flex-direction: column; justify-content: space-between; min-height: 250px; }
.number-input { margin-top: 18px; display: grid; grid-template-columns: 1fr auto; gap: 10px; }
.number-input input { width: 100%; border: 1px solid var(--line); background: white; border-radius: 18px; padding: 14px 16px; outline: none; font-size: 18px; font-weight: 800; color: var(--navy); }
.number-input button { border-radius: 18px; border: none; padding: 0 18px; background: var(--navy); color: white; font-weight: 800; cursor: pointer; }
.guide-note { margin: 0; color: var(--muted); line-height: 1.55; }
.section-title { margin: 34px 0 14px; display: flex; align-items: end; justify-content: space-between; gap: 18px; }
.section-title h3 { margin: 0; color: var(--navy); font-size: clamp(22px, 3.5vw, 36px); letter-spacing: -.04em; }
.section-title small { color: var(--muted); }
.stop-grid { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: 12px; }
.stop-button { position: relative; text-align: left; min-height: 112px; background: rgba(255,255,255,.78); border: 1px solid var(--line); border-radius: 24px; padding: 16px; cursor: pointer; overflow: hidden; transition: transform .18s ease, border-color .18s ease, background .18s ease, box-shadow .18s ease; }
.stop-button:hover { transform: translateY(-2px); box-shadow: 0 12px 28px rgba(18,24,45,.12); }
.stop-button.active { background: var(--navy); color: white; border-color: transparent; box-shadow: 0 18px 42px rgba(24,36,76,.28); }
.stop-button .num { font-size: 38px; line-height: .85; letter-spacing: -.06em; font-weight: 950; color: var(--orange); }
.stop-button.active .num { color: #ffb39f; }
.stop-button .name { margin-top: 10px; font-size: 15px; font-weight: 850; line-height: 1.1; }
.stop-button .meta { margin-top: 5px; font-size: 11px; color: var(--muted); }
.stop-button.active .meta { color: rgba(255,255,255,.65); }
.current-layout { display: grid; grid-template-columns: .92fr 1.08fr; gap: 18px; align-items: start; }
.stop-card { padding: clamp(20px, 3vw, 32px); }
.stop-head { display: grid; grid-template-columns: auto 1fr; gap: 18px; align-items: start; }
.big-num { width: 84px; height: 84px; display: grid; place-items: center; border-radius: 26px; background: var(--orange); color: white; font-size: 42px; font-weight: 950; box-shadow: inset 0 -9px rgba(0,0,0,.08); }
.stop-head h3 { margin: 0; color: var(--navy); font-size: clamp(28px, 4vw, 54px); text-transform: uppercase; letter-spacing: -.055em; line-height: .9; }
.stop-head p { margin: 8px 0 0; color: var(--muted); }
.hook { margin: 22px 0 16px; padding: 18px; border-radius: 22px; background: rgba(240,90,67,.11); color: #442421; font-size: 18px; line-height: 1.45; }
.audio-box { margin: 18px 0; padding: 16px; border-radius: 22px; background: white; border: 1px solid var(--line); }
audio { width: 100%; display: block; }
.audio-message { margin: 10px 0 0; color: var(--muted); font-size: 13px; line-height: 1.4; }
.script { color: #293458; line-height: 1.68; font-size: 16px; }
.look { margin-top: 18px; padding-top: 18px; border-top: 1px solid var(--line); color: #444a62; line-height: 1.55; }
.panel-card { padding: 14px; overflow: hidden; }
.panel-card img { width: 100%; height: auto; display: block; border-radius: 20px; background: white; }
.panel-caption { display: flex; justify-content: space-between; gap: 12px; align-items: center; padding: 12px 6px 2px; color: var(--muted); font-size: 13px; }
.panel-caption button { border: 0; color: var(--navy); background: transparent; font-weight: 800; cursor: pointer; }
.script-card { margin-top: 18px; padding: 22px; }
.script-card h4 { margin: 0 0 12px; color: var(--navy); font-size: 20px; }
.script-card code { background: rgba(24,36,76,.08); padding: 3px 6px; border-radius: 6px; }
.bottom-player { position: fixed; z-index: 10; left: 50%; bottom: 14px; transform: translateX(-50%); width: min(960px, calc(100% - 24px)); background: rgba(18,24,45,.92); color: white; border: 1px solid rgba(255,255,255,.14); backdrop-filter: blur(18px); border-radius: 24px; box-shadow: 0 24px 70px rgba(18,24,45,.35); padding: 12px 14px; display: grid; grid-template-columns: auto 1fr auto; gap: 12px; align-items: center; }
.bottom-player .mini-num { width: 42px; height: 42px; border-radius: 15px; background: var(--orange); display: grid; place-items: center; font-weight: 950; }
.bottom-player strong { display: block; font-size: 14px; }
.bottom-player span { display: block; color: rgba(255,255,255,.65); font-size: 12px; margin-top: 2px; }
.bottom-player button { border: 0; background: rgba(255,255,255,.12); color: white; border-radius: 16px; padding: 12px 14px; cursor: pointer; font-weight: 850; }
.modal { position: fixed; inset: 0; z-index: 20; display: none; place-items: center; background: rgba(11,16,31,.82); padding: 18px; }
.modal.open { display: grid; }
.modal-inner { width: min(1160px, 100%); max-height: 92vh; overflow: auto; background: #fff; border-radius: 24px; padding: 12px; }
.modal img { width: 100%; height: auto; border-radius: 18px; display: block; }
.modal-close { position: fixed; top: 18px; right: 18px; border: 0; border-radius: 999px; background: white; color: var(--navy); padding: 12px 16px; font-weight: 900; cursor: pointer; }
.toast { position: fixed; z-index: 30; top: 18px; right: 18px; background: var(--navy); color: white; padding: 12px 14px; border-radius: 16px; box-shadow: var(--shadow); opacity: 0; transform: translateY(-8px); pointer-events: none; transition: .2s ease; }
.toast.show { opacity: 1; transform: translateY(0); }
@media (max-width: 940px) {
  .hero, .current-layout { grid-template-columns: 1fr; }
  .stop-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .topbar { align-items: flex-start; }
  .mode-pill { display: none; }
}
@media (max-width: 560px) {
  .app-shell { width: min(100% - 20px, 1180px); padding-top: 14px; }
  .brand-mark { width: 46px; height: 46px; border-radius: 15px; }
  .brand p { font-size: 12px; }
  .hero-card, .info-card, .stop-card { border-radius: 22px; }
  .stop-grid { grid-template-columns: 1fr; }
  .stop-button { min-height: 92px; }
  .stop-head { grid-template-columns: 1fr; gap: 10px; }
  .big-num { width: 64px; height: 64px; border-radius: 21px; font-size: 32px; }
  .bottom-player { grid-template-columns: auto 1fr; }
  .bottom-player button { grid-column: 1 / -1; }
}
@media print {
  body { background: white; }
  .hero, .stop-grid, .panel-card, .bottom-player, .modal, .toast { display: none !important; }
  .current-layout { display: block; }
  .app-shell { padding: 0; width: 100%; }
}
</style>
</head>
<body>
<div class="app-shell">
  <header class="topbar">
    <div class="brand">
      <div class="brand-mark" aria-hidden="true"><div class="targets"><span></span><span></span><span></span><span></span></div></div>
      <div>
        <h1>Zlatá trefa</h1>
        <p>Audioguide k výstavě o Josefu Panáčkovi</p>
      </div>
    </div>
    <div class="mode-pill">číslovaná zastavení bez QR kódů</div>
  </header>

  <section class="hero" id="start">
    <div class="hero-card">
      <div class="eyebrow">audio-led guide</div>
      <h2>Vyberte číslo panelu. Poslouchejte příběh.</h2>
      <p class="lead">Průvodce je navržen pro orientaci podle fyzicky vyznačených čísel u panelů. Každé zastavení má vlastní obraz panelu, krátký úvod, audio a text pro další dabing.</p>
      <div class="hero-actions">
        <button class="primary" data-jump="1">Spustit od 1</button>
        <button class="secondary" data-scroll="#stops">Vybrat zastavení</button>
        <button class="ghost" id="copyAllBtn">Zkopírovat texty</button>
      </div>
    </div>
    <aside class="info-card">
      <div>
        <div class="eyebrow">orientace</div>
        <p class="guide-note" style="margin-top:16px;">Na výstavě stačí umístit k panelům čísla <strong>1-10</strong>. Návštěvník v aplikaci zadá stejné číslo. Bez QR kódů, bez skenování, bez složité navigace.</p>
      </div>
      <form class="number-input" id="numberForm">
        <input id="numberInput" inputmode="numeric" pattern="[0-9]*" placeholder="číslo 1-10" aria-label="Zadejte číslo zastavení">
        <button type="submit">Otevřít</button>
      </form>
    </aside>
  </section>

  <div class="section-title" id="stops">
    <h3>Zastavení</h3>
    <small>odpovídá pořadí panelů</small>
  </div>
  <nav class="stop-grid" id="stopGrid" aria-label="Seznam zastavení"></nav>

  <div class="section-title" id="currentTitle">
    <h3>Aktuální zastavení</h3>
    <small id="durationHint"></small>
  </div>
  <section class="current-layout">
    <article class="stop-card">
      <div class="stop-head">
        <div class="big-num" id="currentNum">1</div>
        <div>
          <h3 id="currentStopTitle">Josef Panáček</h3>
          <p id="currentLabel">úvodní zastavení</p>
        </div>
      </div>
      <div class="hook" id="currentHook"></div>
      <div class="audio-box">
        <audio id="audio" controls preload="metadata"></audio>
        <p class="audio-message" id="audioMessage"></p>
      </div>
      <div class="script" id="currentScript"></div>
      <div class="look" id="currentLook"></div>
    </article>
    <aside class="panel-card">
      <img id="panelImage" src="assets/panels/panel-01.jpg" alt="Náhled výstavního panelu">
      <div class="panel-caption"><span id="panelCaption">Panel 1</span><button id="openPanelBtn">Zvětšit panel</button></div>
    </aside>
  </section>

  <section class="script-card">
    <h4>Jak doplnit další audio</h4>
    <p class="guide-note">Nahrajte soubory MP3 do složky <code>assets/audio</code> a pojmenujte je podle čísel zastavení: <code>02-atlet.mp3</code>, <code>03-myslivec.mp3</code> atd. Aplikace už na tyto soubory odkazuje; po doplnění se začnou přehrávat bez změny rozhraní.</p>
  </section>
</div>

<div class="bottom-player" id="bottomPlayer" aria-live="polite">
  <div class="mini-num" id="miniNum">1</div>
  <div><strong id="miniTitle">Josef Panáček</strong><span id="miniMeta">úvodní zastavení</span></div>
  <button id="playPauseBtn">Přehrát / pauza</button>
</div>

<div class="modal" id="panelModal" role="dialog" aria-modal="true" aria-label="Zvětšený panel">
  <button class="modal-close" id="closeModalBtn">Zavřít</button>
  <div class="modal-inner"><img id="modalImage" alt="Zvětšený náhled panelu"></div>
</div>
<div class="toast" id="toast">Hotovo</div>

<script>
const STOPS = [
  {
    "id": 1,
    "title": "Josef Panáček",
    "label": "úvodní zastavení",
    "audio": "assets/audio/01-josef-panacek.mp3",
    "panel": "assets/panels/panel-01.jpg",
    "durationHint": "vložené audio: přibližně 3:17",
    "hook": "Jeden život, několik podob: student, atlet, myslivec, střelec, olympijský vítěz, manžel a legenda.",
    "script": "Stojíte před úvodem do příběhu Josefa Panáčka. Narodil se ve Starém Městě v roce 1937 a jeho život od počátku nesl stopy velkých dějin. Jako dítě zažil válku, ztrátu sestry při bombardování cukrovaru i poválečné změny, které rodině vzaly živnost. Původně měl převzít otcovo autodopravní řemeslo, místo toho se vyučil soustružníkem, začal sportovat a po návratu domů pracoval v průmyslu. Zásadní zlom přišel na střelnici nedaleko Salaše. Od pistole se postupně dostal k brokovnici a ke skeetu - disciplíně, která mu přinesla největší sportovní úspěch. V roce 1976 se v Montrealu stal olympijským vítězem. Výstava jej ale nepředstavuje jen jako držitele zlaté medaile. Ukazuje člověka s pevnými kořeny ve Slovácku, myslivce, manžela, trenéra a osobnost, která zůstala skromná i ve chvíli, kdy dosáhla sportovního vrcholu.",
    "look": "Na úvodním panelu sledujte proměnu jedné osobnosti v několika fotografických rolích - od studenta a atleta až po olympijského vítěze."
  },
  {
    "id": 2,
    "title": "Atlet",
    "label": "začátek sportovní dráhy",
    "audio": "assets/audio/02-atlet.mp3",
    "panel": "assets/panels/panel-02.jpg",
    "durationHint": "doporučená délka voiceoveru: 1:15-1:30",
    "hook": "Než přišla brokovnice, byla tu koule, hřiště a tvrdý trénink.",
    "script": "Sportovní příběh Josefa Panáčka nezačal na střelnici, ale na atletickém hřišti. Na učilišti v Hradci Králové se v padesátých letech dostal ke kouli téměř náhodou. Sám později vzpomínal, že nejdřív jen odkoukal, jak se koule drží - a protože neskončil poslední, začalo ho to bavit. Trénoval každou volnou chvíli a brzy získal přezdívku Skobla podle známého československého koulaře. V roce 1956 se stal mistrem republiky staršího dorostu výkonem 15,45 metru. Atletice zůstal věrný i během vojenské služby a později jako člen Slovácké Slavie Uherské Hradiště. Důležitá tu není jen disciplína samotná. Atletika Panáčka naučila práci s tělem, pravidelnosti a odolnosti. Vlastnosti, které se později přenesly do skeetu, kde o výsledku rozhodují zlomky vteřiny, přesný pohyb a schopnost opakovat jej znovu a znovu.",
    "look": "Fotografie vrhu koulí připomíná, že budoucí olympijský vítěz nejprve hledal svůj sportovní výraz v atletice."
  },
  {
    "id": 3,
    "title": "Myslivec",
    "label": "příroda, lov a střelnice",
    "audio": "assets/audio/03-myslivec.mp3",
    "panel": "assets/panels/panel-03.jpg",
    "durationHint": "doporučená délka voiceoveru: 1:45-2:10",
    "hook": "Panáček o sobě říkal, že je nejdřív myslivec - a teprve potom střelec.",
    "script": "U Josefa Panáčka nelze oddělit sportovní střelbu od myslivosti. Myslivecký kurz absolvoval po vyučení v roce 1955 a o rok později mohl požádat o lovecký lístek. Jeho první zbraní byla kozlice ráže šestnáct značky Holek. Stal se také členem mysliveckého spolku ve Starém Městě. Právě soutěže Českého mysliveckého svazu ho v šedesátých letech přivedly k výraznějším střeleckým úspěchům. Skeet mu byl blízký i proto, že připomínal pohyb a základní postoj při lovu. Z myslivosti tedy nevyrůstal jen koníček, ale i sportovní dráha. Po ukončení kariéry se k ní Panáček znovu vrátil naplno. S manželkou se přestěhoval na Salaš, kde se stal správcem tamější střelnice. Od roku 2023 se zde koná Memoriál olympijského vítěze Josefa Panáčka. Toto zastavení proto ukazuje Panáčka jako člověka krajiny, honitby a střelnice - ne pouze jako sportovce na výsledkové listině.",
    "look": "Všimněte si kombinace loveckých fotografií, společných snímků a portrétu se zbraní. Panel staví vedle sebe osobní zálibu i základ budoucí sportovní specializace."
  },
  {
    "id": 4,
    "title": "Střelec",
    "label": "disciplína, dřina, rutina",
    "audio": "assets/audio/04-strelec.mp3",
    "panel": "assets/panels/panel-04.jpg",
    "durationHint": "doporučená délka voiceoveru: 2:15-2:45",
    "hook": "Olympijské zlato nevysvětluje náhoda. Tady začíná technika, trénink a opakování.",
    "script": "Přestože si Josefa Panáčka spojujeme hlavně se skeetem, začínal jako pistolář. V letech 1958 až 1965 závodil spíše na okresní úrovni. Brzy se však začal věnovat brokovnici a jeho výkonnost rostla. V roce 1971 nastřílel československý rekord 198 terčů z 200, čímž zároveň vyrovnal světový rekord. O rok později se stal mistrem republiky a v roce 1973 přišla první velká mezinárodní medaile - bronz družstva na mistrovství Evropy v Turíně. Zásadní bylo zařazení do střediska vrcholového sportu Rudá hvězda Brno, které vzniklo v roce 1975. Panáček trénoval ve skupině Vlastimíra Málka. Trénink nebyl jen střelba. Znamenal tisíce opakování nahazování zbraně do ramene, posilování, běh, fotbal i stolní tenis pro postřeh. V zimě probíhal suchý trénink bez střeliva. Panáček sám tvrdil, že na střelbu nemá výjimečný talent a že za úspěchem byla především dřina. Právě tato věta je klíčem k jeho kariéře: legenda nevznikla z okázalosti, ale z přesnosti, práce a každodenní rutiny.",
    "look": "Na panelu dominuje fotografie Panáčka jako pistoláře. Kontrastuje s textem, který vysvětluje jeho cestu od pistole ke skeetu a k vrcholovému sportu."
  },
  {
    "id": 5,
    "title": "Mistrovství Evropy",
    "label": "medaile před i po Montrealu",
    "audio": "assets/audio/05-mistrovstvi-evropy.mp3",
    "panel": "assets/panels/panel-05.jpg",
    "durationHint": "doporučená délka voiceoveru: 1:45-2:20",
    "hook": "Evropská mistrovství ukazují Panáčka v nejtěžší roli: jako olympijského vítěze, který musí znovu potvrzovat svou výkonnost.",
    "script": "První evropskou medaili získal Josef Panáček v roce 1973 v Turíně, tehdy ještě jako člen bronzového družstva. Po olympijském vítězství v Montrealu se ale změnilo všechno. Už nebyl nenápadným střelcem z Československa. Stal se mužem, kterého sledovali soupeři, diváci i odborníci. Na mistrovství Evropy v Dorsetu v roce 1977 vybojoval mezi jednotlivci stříbro výkonem 197 z 200. Další stříbro přidal s družstvem. V letech 1978 a 1979 následovaly týmové medaile ze Suhlu a Montecatini. Zdálo se, že individuální titul už nepřijde, ale v roce 1980 v Zaragoze využil Panáček zkušenosti i odolnost. Po základní části měl stejný nástřel jako o třiadvacet let mladší Francouz Bruno Rossetti. Rozhodoval rozstřel. A stejně jako v Montrealu Panáček zvládl tlak lépe. Získal titul mistra Evropy. Toto zastavení ukazuje, že jeho kariéra nebyla jediným šťastným okamžikem, ale dlouhou sérií výkonů na hranici světové špičky.",
    "look": "Prohlédněte si snímky ze stupňů vítězů a týmových sestav. Panel zachycuje Panáčka nejen jako jednotlivce, ale i jako člena silné československé skeetařské reprezentace."
  },
  {
    "id": 6,
    "title": "Legenda",
    "label": "sláva bez okázalosti",
    "audio": "assets/audio/06-legenda.mp3",
    "panel": "assets/panels/panel-06.jpg",
    "durationHint": "doporučená délka voiceoveru: 1:45-2:15",
    "hook": "Z olympijského zlata se rodí sláva. Panáček ji přijal jinak, než bychom čekali.",
    "script": "Po návratu z Montrealu čekaly Josefa Panáčka pocty, gratulace a veřejné přijetí. Byl vyznamenán Řádem práce, oceněn městem Uherské Hradiště, stal se jedním z nejlepších sportovců Jihomoravského kraje a druhým v anketě Sportovec ČSSR za rok 1976. Přicházely autogramiády, besedy a pozvánky na slavnostní akce. Sláva však pro něj nebyla cílem. Na otázku, jaký je to pocit být slavným, odpověděl, že nejšťastnější je někde v klidu a že obdiv nehledá. Po skončení sportovní kariéry v roce 1983 zůstal u střelby jako trenér. Vedl mladší střelce i reprezentaci, účastnil se mistrovství světa a jako trenér také olympijských her v Barceloně v roce 1992. Přesto nikdy nepůsobil jako typická sportovní celebrita. V roce 1999 se s manželkou přestěhoval na Salaš, kde se starali o střelnici a žili spíše stranou pozornosti. Jeho legenda proto není jen příběhem vítězství. Je to příběh člověka, který dokázal zůstat nenápadný i po mimořádném úspěchu.",
    "look": "Panel pracuje s návratem z olympiády, filmovým dokumentem, trenérskou etapou i pozdějším životem na Salaši. Sledujte, jak se sportovní hrdina mění v tichou autoritu."
  },
  {
    "id": 7,
    "title": "Zdeňka",
    "label": "osobní zázemí",
    "audio": "assets/audio/07-zdenka.mp3",
    "panel": "assets/panels/panel-07.jpg",
    "durationHint": "doporučená délka voiceoveru: 1:35-2:05",
    "hook": "Za sportovním výkonem často stojí někdo, kdo není na stupních vítězů vidět.",
    "script": "Toto zastavení je věnováno Zdeňce Panáčkové, rozené Výchopňové. Josef Panáček o ní v jednom rozhovoru řekl, že bez ní by nebyl nic. Seznámili se v zaměstnání v n. p. Mikrotechna v Mařaticích. Zdeňka pocházela ze Salaše, kam Josef jezdil na blízkou střelnici trénovat. Spojovala je příroda, myslivost i později střelba. Vzali se v roce 1962 a jejich manželství trvalo více než půl století. Zdeňka ho doprovázela na závody, pomáhala mu překonávat obtíže a v dopisech zůstávala oporou i ve chvílích, kdy pochyboval. Během olympiády v Montrealu si psali něžné dopisy - on ji oslovoval Zdenulko, ona jej Papulko. Panel proto rozšiřuje výstavu o intimní rovinu. Ukazuje, že za veřejnou kariérou existuje domácí, partnerský a každodenní příběh. A že i zlatá medaile má své tiché zázemí.",
    "look": "Koláž fotografií a dopisů je nejvíce osobní částí výstavy. Sledujte proměnu od svatebního portrétu po společné chvíle v přírodě a na střelnici."
  },
  {
    "id": 8,
    "title": "Co je skeet?",
    "label": "disciplína pod lupou",
    "audio": "assets/audio/08-co-je-skeet.mp3",
    "panel": "assets/panels/panel-08.jpg",
    "durationHint": "doporučená délka voiceoveru: 2:15-2:45",
    "hook": "Abychom pochopili Panáčkův výkon, musíme vědět, co přesně střelec ve skeetu dělá.",
    "script": "Skeet je sportovní střelecká disciplína, která vznikla ve Spojených státech ve dvacátých letech 20. století. Střílí se na letící terče, lidově nazývané asfaltoví holubi. Terč má průměr 11 centimetrů a je vrhán z vysoké nebo nízké věže. Střelec prochází osmi stanovišti rozmístěnými na půlkruhu a z každého střílí na jednotlivé terče nebo na dvojterče. Právě dvojterč je zvlášť náročný: dva terče letí téměř současně a střelec má na každý jen jeden výstřel. Zbraň nesmí mít předem v rameni. Drží ji dole, v takzvaném skeetovém neboli loveckém postoji, a teprve po svém pokynu k vypuštění terče zbraň zvedá, míří a střílí. Úspěch proto závisí na dokonale zvládnutém pohybu, rychlosti reakce, periferním vidění a psychické stabilitě. V době Panáčkovy kariéry mohl být maximální výsledek 200 zásahů z 200 terčů. Když tedy v Montrealu dosáhl nástřelu 198 z 200, znamenalo to výkon na hranici absolutní přesnosti. Toto zastavení je technickým klíčem k celé výstavě.",
    "look": "Na panelu je schéma osmi stanovišť a popis vysoké i nízké věže. Zkuste sledovat trasu střelce po půlkruhu a představit si rytmus celé položky."
  },
  {
    "id": 9,
    "title": "Olympijský vítěz",
    "label": "Montreal, rozstřel, zlatá rána",
    "audio": "assets/audio/09-olympijsky-vitez.mp3",
    "panel": "assets/panels/panel-09.jpg",
    "durationHint": "doporučená délka voiceoveru: 2:30-3:15",
    "hook": "V Montrealu nebyl favorit. Právě proto je jeho vítězství tak silný příběh.",
    "script": "Josef Panáček se mohl na olympijských hrách objevit už v roce 1972 v Mnichově, ale nakonec neodjel. O čtyři roky později, v osmatřiceti letech, už byl v nominaci pro Montreal. Do soutěže vstupoval bez nálepky favorita. Předchozí mezinárodní výsledky byly kolísavé a týden před závodem psal manželce, že tréninky se mu nedaří a že má z nastávající soutěže hrůzu. Jenže závod ukázal něco jiného. Po sedmi kolech vedl Nizozemec Eric Swinkels s jedinou chybou, Panáček byl hned za ním. V posledním kole Panáček trefil všech 25 terčů a soutěž zakončil výkonem 198 z 200, čímž vyrovnal olympijský rekord. Swinkels jednou minul a rozhodoval rozstřel. V prvním oba jednou chybovali. Ve druhém už Panáček neudělal chybu, zatímco Swinkels minul. Touto zlatou střelou se Josef Panáček stal olympijským vítězem. Na dalších hrách v Moskvě v roce 1980 už přijížděl v roli obhájce a mistra Evropy, ale skončil mimo medaile. Olympijská kapitola tím skončila - alespoň jako závodník. Později se na hry vrátil ještě jako trenér.",
    "look": "Všimněte si zápisu z rozstřelu, fotografie stupňů vítězů a dopisu z olympijské vesnice. Panel spojuje sportovní drama s osobní nejistotou před závodem."
  },
  {
    "id": 10,
    "title": "Olympijské hry v Montrealu 1976",
    "label": "světový kontext vítězství",
    "audio": "assets/audio/10-montreal-1976.mp3",
    "panel": "assets/panels/panel-10.jpg",
    "durationHint": "doporučená délka voiceoveru: 1:45-2:20",
    "hook": "Panáčkovo zlato vzniklo v konkrétním čase: na hrách plných sportovních rekordů, politiky i paradoxů.",
    "script": "Letní olympijské hry v Montrealu se konaly od 17. července do 1. srpna 1976. Zúčastnilo se jich 92 zemí, méně než na předchozích hrách v Mnichově, protože většina afrických států hry bojkotovala. Montreal se stal symbolem mimořádných výkonů i obrovských organizačních nákladů. Stadion byl při zahájení nedokončený a olympijský dluh město splácelo dlouhá desetiletí. Do dějin vstoupila rumunská gymnastka Nadia Comăneci, která jako první získala absolutní známku 10,00, i příběh olympijského ohně, který po dešti musel být znovu zapálen z původního plamene. Československo reprezentovalo 167 sportovců a získalo osm medailí. Zlaté byly dvě: Anton Tkáč v cyklistice a Josef Panáček ve sportovní střelbě. Toto poslední zastavení zasazuje Panáčkův úspěch do širšího obrazu her. Nešlo jen o osobní triumf. Byla to jedna z nejvýraznějších československých medailí olympiády, která sama patří k nejpozoruhodnějším sportovním událostem sedmdesátých let.",
    "look": "Panel doplňuje týmovou fotografii, logo Montrealu a maskota Amika. Slouží jako epilog: z osobního příběhu se vracíme do velkých dějin sportu."
  }
];
let current = STOPS[0];
const grid = document.getElementById('stopGrid');
const audio = document.getElementById('audio');
const audioMessage = document.getElementById('audioMessage');
const toast = document.getElementById('toast');

function showToast(text) {
  toast.textContent = text;
  toast.classList.add('show');
  setTimeout(() => toast.classList.remove('show'), 1800);
}

function renderGrid() {
  grid.innerHTML = '';
  STOPS.forEach(stop => {
    const btn = document.createElement('button');
    btn.className = 'stop-button';
    btn.dataset.id = stop.id;
    btn.innerHTML = `<div class="num">${String(stop.id).padStart(2,'0')}</div><div class="name">${stop.title}</div><div class="meta">${stop.label}</div>`;
    btn.addEventListener('click', () => setStop(stop.id, true));
    grid.appendChild(btn);
  });
}

function setStop(id, push=true) {
  const stop = STOPS.find(s => s.id === Number(id)) || STOPS[0];
  current = stop;
  document.querySelectorAll('.stop-button').forEach(b => b.classList.toggle('active', Number(b.dataset.id) === stop.id));
  document.getElementById('currentNum').textContent = stop.id;
  document.getElementById('currentStopTitle').textContent = stop.title;
  document.getElementById('currentLabel').textContent = stop.label;
  document.getElementById('currentHook').textContent = stop.hook;
  document.getElementById('currentScript').textContent = stop.script;
  document.getElementById('currentLook').textContent = stop.look;
  document.getElementById('durationHint').textContent = stop.durationHint || '';
  document.getElementById('panelImage').src = stop.panel;
  document.getElementById('panelImage').alt = `Náhled panelu ${stop.id}: ${stop.title}`;
  document.getElementById('panelCaption').textContent = `Panel ${stop.id} / ${stop.title}`;
  document.getElementById('miniNum').textContent = stop.id;
  document.getElementById('miniTitle').textContent = stop.title;
  document.getElementById('miniMeta').textContent = stop.label;
  audio.pause();
  audio.src = stop.audio;
  audio.load();
  audioMessage.textContent = stop.id === 1 ? 'Audio je připojeno. Text v aplikaci je doprovodný návrh, nikoli nutně doslovný přepis nahrávky.' : `Audio soubor se očekává jako ${stop.audio}. Pokud zde zatím není, přehrávač oznámí chybu; po doplnění MP3 začne fungovat.`;
  if (push) {
    const url = new URL(window.location);
    url.searchParams.set('stop', stop.id);
    history.replaceState(null, '', url);
    document.getElementById('currentTitle').scrollIntoView({behavior:'smooth', block:'start'});
  }
}

audio.addEventListener('error', () => {
  if (current.id !== 1) audioMessage.textContent = `Zvukové zastavení zatím není připojeno. Doplňte soubor: ${current.audio}.`;
});

document.getElementById('numberForm').addEventListener('submit', (e) => {
  e.preventDefault();
  const val = document.getElementById('numberInput').value.trim();
  const id = Number(val);
  if (id >= 1 && id <= STOPS.length) setStop(id, true); else showToast('Zadejte číslo 1-10.');
});

document.querySelectorAll('[data-jump]').forEach(btn => btn.addEventListener('click', () => setStop(btn.dataset.jump, true)));
document.querySelectorAll('[data-scroll]').forEach(btn => btn.addEventListener('click', () => document.querySelector(btn.dataset.scroll).scrollIntoView({behavior:'smooth'})));

document.getElementById('openPanelBtn').addEventListener('click', () => {
  document.getElementById('modalImage').src = current.panel;
  document.getElementById('panelModal').classList.add('open');
});
document.getElementById('closeModalBtn').addEventListener('click', () => document.getElementById('panelModal').classList.remove('open'));
document.getElementById('panelModal').addEventListener('click', (e) => { if (e.target.id === 'panelModal') e.currentTarget.classList.remove('open'); });

document.getElementById('playPauseBtn').addEventListener('click', () => {
  if (audio.paused) audio.play().catch(() => showToast('Audio zatím nelze přehrát.')); else audio.pause();
});

document.getElementById('copyAllBtn').addEventListener('click', async () => {
  const text = STOPS.map(s => `${s.id}. ${s.title}
${s.script}
`).join('
');
  try { await navigator.clipboard.writeText(text); showToast('Texty zkopírovány.'); }
  catch { showToast('Kopírování není v tomto prohlížeči povoleno.'); }
});

document.addEventListener('keydown', (e) => {
  if (['INPUT','TEXTAREA'].includes(document.activeElement.tagName)) return;
  if (/^[1-9]$/.test(e.key)) setStop(Number(e.key), true);
  if (e.key === '0') setStop(10, true);
  if (e.key === 'Escape') document.getElementById('panelModal').classList.remove('open');
});

renderGrid();
const initial = new URL(window.location).searchParams.get('stop') || 1;
setStop(initial, false);
if ('serviceWorker' in navigator && location.protocol.startsWith('http')) {
  navigator.serviceWorker.register('service-worker.js').catch(() => {});
}
</script>
</body>
</html>
